                "subtree_start_index": 270,
                "subtree_end_index": 270,
                "nodes": []
              },
              {
                "title": "10.9 Where campaign manufacture is carried out, the impact on the ease of cleaning at the end of the campaign should be considered and the maximum length of a campaign (in time and/or number of batches)",
                "node_id": "0327",
                "start_index": 270,
