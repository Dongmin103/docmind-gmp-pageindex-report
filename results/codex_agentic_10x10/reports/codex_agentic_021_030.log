                "nodes": []
              },
              {
                "title": "10.2 A visual check for cleanliness is an important part of the acceptance criteria for cleaning validation. It is not generally acceptable for this criterion alone to be used. Repeated cleaning and retesting until acceptable residue results",
                "node_id": "0318",
                "start_index": 270,
