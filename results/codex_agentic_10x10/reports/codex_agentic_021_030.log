                "own_end_index": 270,
                "subtree_start_index": 270,
                "subtree_end_index": 270,
                "nodes": []
              },
              {
                "title": "10.6.2 If it is not feasible to test for specific product residues, other representative parameters may be selected, e.g. total organic carbon (TOC) and conductivity.",
                "node_id": "0324",
                "start_index": 270,
                "end_index": 270,
                "own_start_index": 270,
